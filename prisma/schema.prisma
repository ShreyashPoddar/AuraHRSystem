generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id         String     @id @default(cuid())
  name       String
  email      String     @unique
  role       String
  skills     String[]
  department String
  location   String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model JobDescription {
  id          String   @id @default(cuid())
  role        String
  description String
  mustHave    String[]
  goodToHave  String[]
  futureProof String[]
  teamGap     String[]
  createdAt   DateTime @default(now())
  candidates  Candidate[]
}

model Candidate {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  skills         String[]
  experience     Int?
  education      String?
  location       String?
  resumeUrl      String?
  matchScore     Int?
  authenticity   Int?
  status         String   @default("APPLIED")
  
  // External Footprints
  githubUrl      String?
  linkedInUrl    String?
  kaggleUrl      String?
  
  // Future Match Scoring
  futureProofScore Float?  @default(0)
  
  // Relations
  jdId           String?
  jobDescription JobDescription? @relation(fields: [jdId], references: [id])
  interviews     Interview[]
  proctoringLogs ProctoringLog[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Interview {
  id              String    @id @default(cuid())
  candidateId     String
  candidate       Candidate @relation(fields: [candidateId], references: [id])
  scheduledAt     DateTime
  method          String    @default("video")
  status          String    @default("scheduled")
  meetingLink     String?
  aiScore         Float?
  aiFeedback      String?
  createdAt       DateTime  @default(now())
}

model ProctoringLog {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  eventType   String    // TAB_SWITCH, NO_FACE, GAZE_AWAY
  timestamp   DateTime  @default(now())
  severity    String    @default("low")
  metadata    String?   // JSON details
}

model MarketTrend {
  id        String   @id @default(cuid())
  skillName String   @unique
  demand    Float    // 0 to 1
  growth    Float    // Percentage
  updatedAt DateTime @updatedAt
}
